NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI authentication
# Dev: uses `claude` CLI subprocess (subscription auth). No key needed.
# Prod: set to a console API key (sk-ant-api03-*).
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# FORCE_SDK=true  # uncomment to use SDK instead of CLI in dev

NEXT_PUBLIC_HAS_LOCAL_KEY=true
MODEL_AISLING=claude-sonnet-4-6
MODEL_LIGHT_ASSESSMENT=claude-haiku-4-5-20251001
